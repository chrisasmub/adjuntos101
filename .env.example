# Runtime local del worker. Ajustar al path real del entorno.
ADJUNTOS_BASE_DIR=/path/to/ADJUNTOS
SCAN_INTERVAL_SECONDS=30
MIN_FILE_AGE_SECONDS=90
STABLE_CHECK_INTERVAL_SECONDS=5
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,xlsx,xls

DATABASE_MODE=iris
IRIS_HOST=localhost
IRIS_PORT=1972
# Namespace canonico de esta POC en IRIS.
IRIS_NAMESPACE=USER
# Usuario de aplicacion con permisos DML sobre SQLUser.*
IRIS_USERNAME=admin
IRIS_PASSWORD=change_me

PARSER_MODE=mock
LLAMAPARSE_API_KEY=replace_with_real_key
LLAMAPARSE_BASE_URL=https://api.cloud.llamaindex.ai/api/v2
LLAMAPARSE_DEFAULT_TIER=cost_effective
LLAMAPARSE_COMPLEX_TIER=agentic
LLAMAPARSE_VERSION=latest
LLAMAPARSE_POLL_SECONDS=5
LLAMAPARSE_TIMEOUT_SECONDS=300
LLAMAPARSE_MAX_RETRIES=2
LLAMAPARSE_RETRY_BACKOFF_SECONDS=2

LOG_LEVEL=INFO
